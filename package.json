{
  "name": "rnk-quick-chug",
  "version": "1.2.6",
  "description": "A bonus action potion quick-access system for faster, more heroic potion use in combat.",
  "main": "scripts/main.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "npm run test -- --coverage",
    "build": "npm run lint && npm run test:coverage",
    "lint": "eslint scripts/ --fix",
    "dev": "echo 'Development mode - symlink module to Foundry Data/modules'",
    "release": "echo 'Prepare release: version bump, changelog, git tag'"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": ["foundry", "foundry-vtt", "foundry-module", "potion", "consumable", "qol", "bonus-action"],
  "author": "The Curator",
  "license": "RNK-PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/RNK-Enterprise/rnk-quick-chug.git"
  },
  "bugs": {
    "url": "https://github.com/RNK-Enterprise/rnk-quick-chug/issues"
  },
  "homepage": "https://patreon.com/rnk",
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
